VALUE uint128_to_hex_string(tb_uint128_t value) {
  if (NIL_P(value)) {
    return UINT2NUM(0);
  }

  char buffer[33];
  uint64_t high = (uint64_t)(value >> 64);
  uint64_t low = (uint64_t)value;

  snprintf(buffer, sizeof(buffer), "%016" "ll" "x" "%016" "ll" "x", high, low);
  return rb_str_new_cstr(buffer);
}

tb_uint128_t hex_string_to_uint128(VALUE str) {
  if (NIL_P(str)) {
    return 0;
  }

  Check_Type(str, T_STRING);

  char *hex_str = StringValuePtr(str);
  tb_uint128_t result = 0;


  for (long i = 0; i < RSTRING_LEN(str); i++) {
    char c = hex_str[i];
    int val = 0;

    if (c >= '0' && c <= '9') val = c - '0';
    else if (c >= 'a' && c <= 'f') val = c - 'a' + 10;
    else if (c >= 'A' && c <= 'F') val = c - 'A' + 10;
    else continue;

    result = (result << 4) | val;
  }

  return result;
}
